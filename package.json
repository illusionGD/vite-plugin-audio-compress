{
    "name": "vite-plugin-audio-compress",
    "version": "1.0.1",
    "description": "Vite audio compression and format conversion plugin",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./type": {
            "types": "./dist/plugin-options.d.ts"
        }
    },
    "files": [
        "dist",
        "README.md",
        "README.zh-CN.md",
        "LICENSE"
    ],
    "scripts": {
        "dev": "pnpm run playground:dev",
        "commit": "git add . && cz",
        "push": "npm run commit && git push",
        "build": "rolldown -c && tsc -p tsconfig.json --emitDeclarationOnly",
        "release": "changeset add && changeset version",
        "publish:release": "npm run release && npm run push",
        "lint": "eslint \"src/**/*.{ts,tsx}\" \"examples/**/*.ts\"",
        "format": "prettier --write .",
        "changeset": "changeset",
        "cz": "cz"
    },
    "keywords": [],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "execa": "^9.6.0",
        "ffmpeg-static": "^5.2.0",
        "picocolors": "^1.1.1"
    },
    "devDependencies": {
        "@changesets/cli": "^2.31.0",
        "@eslint/js": "^9.39.2",
        "@rollup/pluginutils": "^5.1.0",
        "@types/ffmpeg-static": "^5.1.0",
        "@types/node": "^25.6.0",
        "@typescript-eslint/eslint-plugin": "^8.43.0",
        "@typescript-eslint/parser": "^8.43.0",
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^10.2.1",
        "globals": "^16.0.0",
        "prettier": "^3.8.3",
        "rolldown": "1.0.0-rc.16",
        "typescript": "^6.0.3"
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    }
}